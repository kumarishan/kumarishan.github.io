---
export interface Props {
  type?: "info" | "warning" | "tip" | "danger";
  title?: string;
}

const { type = "info", title } = Astro.props;

const defaults: Record<NonNullable<Props["type"]>, string> = {
  info: "Info",
  warning: "Warning",
  tip: "Tip",
  danger: "Danger",
};

const label = title ?? defaults[type];
---

<aside class={`callout callout--${type}`} role="note">
  <p class="callout__label">{label}</p>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    @apply my-6 rounded-md border-l-4 px-5 py-4;
  }
  .callout__label {
    @apply mb-2 font-semibold uppercase tracking-wide;
    font-size: 0.75rem;
  }
  .callout__body :global(p:last-child) {
    @apply mb-0;
  }

  /* info — uses site accent colour */
  .callout--info {
    border-color: rgb(var(--color-accent));
    background: rgba(var(--color-accent), 0.08);
  }
  .callout--info .callout__label {
    color: rgb(var(--color-accent));
  }

  /* tip — green */
  .callout--tip {
    @apply border-green-500;
    background: rgba(34, 197, 94, 0.08);
  }
  .callout--tip .callout__label {
    @apply text-green-600 dark:text-green-400;
  }

  /* warning — amber */
  .callout--warning {
    @apply border-amber-500;
    background: rgba(245, 158, 11, 0.08);
  }
  .callout--warning .callout__label {
    @apply text-amber-600 dark:text-amber-400;
  }

  /* danger — red */
  .callout--danger {
    @apply border-red-500;
    background: rgba(239, 68, 68, 0.08);
  }
  .callout--danger .callout__label {
    @apply text-red-600 dark:text-red-400;
  }
</style>
