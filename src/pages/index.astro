---
import Card from "@components/Card";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Hr from "@components/Hr.astro";
import LinkButton from "@components/LinkButton.astro";
import Socials from "@components/Socials.astro";
import { SOCIALS } from "@config";
import Layout from "@layouts/Layout.astro";
import { getAllPosts } from "@utils/getAllPosts";

const sortedPosts = await getAllPosts();
const featuredPosts = sortedPosts.filter(post => post.featured);
const recentPosts = sortedPosts.filter(post => !post.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>The Learning Curve</h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="rss-link"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon"
          ><path
            d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"
          ></path><path
            d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"
          ></path><circle cx="6" cy="18" r="2"></circle>
        </svg>
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        Hey 👋 Ishan here. This is where I share my adventures in AI, startups,
        and productivity, along with updates on my latest projects. Let’s
        conquer the learning curve together and enjoy every step!
      </p>
      {
        // only display if at least one social link is enabled
        socialCount > 0 && (
          <div class="social-wrapper">
            <div class="social-links">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <h2>Featured</h2>
            <ul>
              {featuredPosts.map(post => (
                <Card href={post.href} frontmatter={post} secHeading={false} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (post, index) =>
                index < 4 && (
                  <Card
                    href={post.href}
                    frontmatter={post}
                    secHeading={false}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    <div class="all-posts-btn-wrapper">
      <LinkButton href="/posts/">
        All Posts
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-8 pt-10;
  }
  #hero h1 {
    @apply my-4 inline-block sm:my-8;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  #hero .rss-link {
    @apply mb-6 inline-flex rounded-sm border border-skin-line bg-skin-card px-3 py-2;
  }
  #hero .rss-icon {
    @apply h-5 w-5 scale-100 fill-skin-accent;
  }
  #hero p {
    @apply my-4 max-w-2xl text-lg;
    color: rgba(var(--color-text-base), 0.82);
  }
  .social-wrapper {
    @apply mt-6 flex flex-col sm:flex-row sm:items-center;
  }
  .social-links {
    @apply mb-2 mr-3 whitespace-nowrap sm:mb-0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts {
    @apply pb-6 pt-12;
  }
  #featured h2,
  #recent-posts h2 {
    @apply text-2xl;
    font-family: var(--font-serif);
    font-weight: 700;
  }
  .all-posts-btn-wrapper {
    @apply my-8 text-center;
  }
  .all-posts-btn-wrapper a {
    @apply inline-flex items-center gap-2 rounded-sm border border-skin-line bg-skin-card px-4 py-2;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
